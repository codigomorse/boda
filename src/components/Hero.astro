---
---

<section class="hero">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-subtitle">28 de Noviembre de 2026</p>
    <h1 class="hero-title">¡Nos Casamos!</h1>
    <p class="hero-names">Daniela & Omar</p>
    <div class="hero-divider">
      <span></span>
      <span class="heart">♥</span>
      <span></span>
    </div>
    <p class="hero-invitation">Te invitamos a celebrar nuestro gran día</p>
  </div>
  <a href="#countdown" class="scroll-indicator" aria-label="Ir a cuenta regresiva">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/novios.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.5) 50%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: var(--color-white);
    padding: var(--spacing-md);
    animation: fadeIn 1.5s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-md);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: var(--spacing-sm);
    opacity: 0.9;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 4rem;
    color: var(--color-white);
    margin-bottom: var(--spacing-xs);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .hero-names {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    margin: var(--spacing-md) 0;
  }

  .hero-divider span:first-child,
  .hero-divider span:last-child {
    width: 60px;
    height: 1px;
    background-color: var(--color-primary);
  }

  .hero-divider .heart {
    color: var(--color-primary);
    font-size: 1.5rem;
  }

  .hero-invitation {
    font-family: var(--font-body);
    font-size: var(--font-size-lg);
    font-style: italic;
    opacity: 0.9;
  }

  .scroll-indicator {
    position: absolute;
    bottom: var(--spacing-lg);
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-white);
    font-size: 2rem;
    animation: bounce 2s infinite;
    z-index: 1;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .scroll-indicator:hover {
    opacity: 1;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    40% {
      transform: translateX(-50%) translateY(-10px);
    }
    60% {
      transform: translateX(-50%) translateY(-5px);
    }
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 6rem;
    }

    .hero-names {
      font-size: 3.5rem;
    }

    .hero-subtitle {
      font-size: var(--font-size-lg);
    }

    .hero-invitation {
      font-size: var(--font-size-xl);
    }
  }
</style>
