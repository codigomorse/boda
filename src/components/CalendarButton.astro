---
const eventTitle = "Boda Nombre & Nombre";
const eventDate = "20261128T160000";
const eventEndDate = "20261128T230000";
const eventLocation = "La Paz, Canelones, Uruguay";
const eventDescription = "Te invitamos a nuestra boda. ¡Nos encantaría que celebraras con nosotros!";

const googleCalendarUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(eventTitle)}&dates=${eventDate}/${eventEndDate}&location=${encodeURIComponent(eventLocation)}&details=${encodeURIComponent(eventDescription)}`;
---

<section class="calendar-section">
  <div class="container text-center">
    <a href={googleCalendarUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary calendar-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      Agregar a Google Calendar
    </a>
  </div>
</section>

<style>
  .calendar-section {
    padding: var(--spacing-lg) 0;
    background-color: var(--color-background);
  }

  .calendar-btn {
    gap: var(--spacing-sm);
  }

  .calendar-btn svg {
    flex-shrink: 0;
  }
</style>
